@article{thomas2025vaequwgan,
  abbr={QMI},
  bibtex_show={true},
  title={VAE-QWGAN: Addressing Mode Collapse in Quantum GANs via Autoencoding Priors},
  author={Thomas*, Aaron M. and Youel*, Harry and Jose, Sharu Theresa},
  abstract={Quantum Generative Adversarial Networks (QGANs) are a promising class of hybrid quantum–classical generative models, yet they remain susceptible to mode collapse—a critical failure where the generator learns only a subset of the target distribution. We propose VAE-QWGAN, a hybrid model that integrates variational autoencoder priors with a quantum Wasserstein GAN framework to alleviate mode collapse. By conditioning the quantum generator on a learned latent space, our approach improves sample diversity and quality on benchmark quantum generative modelling tasks.},
  journal={Quantum Machine Intelligence},
  volume={7},
  pages={91},
  year={2025},
  publisher={Springer},
  doi={10.1007/s42484-025-00277-1},
  selected={true},
  annotation={* Equal contribution}
}

@inproceedings{thomas2025qcamolgan,
  abbr={IEEE QAI},
  bibtex_show={true},
  title={QCA-MolGAN: Quantum Circuit Associative Molecular GAN with Multi-Agent Reinforcement Learning},
  author={Thomas, Aaron M. and Chen, Yixuan and Valencia, Hector O. and Jose, Sharu Theresa and Wu, Runzhe},
  abstract={We present QCA-MolGAN, an enhanced hybrid quantum generative adversarial network for molecular drug discovery. Our framework couples quantum circuit associativity with multi-agent reinforcement learning to guide molecular generation toward desired pharmacological properties, achieving improved validity and drug-likeness scores compared to purely classical baselines.},
  booktitle={IEEE International Conference on Quantum Artificial Intelligence},
  year={2025},
  publisher={IEEE},
  selected={true}
}

@article{georgiou2025generalization,
  abbr={arXiv},
  bibtex_show={true},
  title={On the Generalization of Adversarially Trained Quantum Classifiers},
  author={Georgiou, Petros and Thomas, Aaron M. and Jose, Sharu Theresa and Simeone, Osvaldo},
  abstract={We provide a theoretical analysis of adversarially trained quantum classifiers, deriving novel PAC-learning and Rademacher-complexity-based generalization bounds. Our bounds explicitly quantify how the choice of quantum data embedding and the adversarial attack model jointly determine sample complexity and adversarial robustness, offering new insights into the security–generalization trade-off for quantum machine learning models.},
  journal={arXiv preprint},
  year={2025},
  arxiv={2504.00000},
  selected={true}
}

@inproceedings{thomas2025sparse,
  abbr={ACL},
  bibtex_show={true},
  title={Refined Salience-Aware Sparse Fine-Tuning of Large Language Models},
  author={Thomas, Aaron M. and others},
  abstract={We propose refined salience-aware sparse fine-tuning strategies for large language models that achieve superior parameter efficiency and downstream task performance. By identifying and updating only the most salient parameters according to gradient-based importance measures, our method consistently outperforms existing sparse fine-tuning baselines across a range of NLP benchmarks.},
  booktitle={Proceedings of the 63rd Annual Meeting of the Association for Computational Linguistics (ACL 2025)},
  year={2025},
  publisher=acl,
  selected={false}
}
